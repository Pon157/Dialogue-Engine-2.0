# PostgreSQL
DATABASE_URL=postgresql+asyncpg://botconstructor:botconstructor@localhost:5432/botconstructor

# Токен ГЛАВНОГО бота-конструктора (через него владельцы создают/настраивают своих ботов)
MASTER_BOT_TOKEN=123456:AAAA-your-master-bot-token

# Как часто (в секундах) движок проверяет БД на предмет новых/изменённых/удалённых ботов
BOT_POLL_INTERVAL=5
